{
  "id": "general-social-orchestrator",
  "name": "General Social Orchestrator",
  "version": "1.2.0",
  "description": "Unified bridge for multi-platform social media publishing via Sultan Soul API with Granular CLI Auth.",
  "skills": ["./skills"],
  "configSchema": {
    "type": "object",
    "properties": {
      "licenseKey": { "type": "string" },
      "deviceId": { "type": "string" },
      "fb": {
        "type": "object",
        "properties": {
          "page_id": { "type": "string" },
          "access_token": { "type": "string" }
        }
      },
      "ig": {
        "type": "object",
        "properties": {
          "ig_user_id": { "type": "string" },
          "access_token": { "type": "string" }
        }
      },
      "x": {
        "type": "object",
        "properties": {
          "api_key": { "type": "string" },
          "api_secret": { "type": "string" },
          "access_token": { "type": "string" },
          "access_secret": { "type": "string" }
        }
      },
      "threads": {
        "type": "object",
        "properties": {
          "access_token": { "type": "string" }
        }
      }
    }
  },
  "commands": {
    "fb-auth": {
      "handler": "./index.js:fbAuth",
      "description": "Authenticate Facebook Page",
      "args": "[page_id] [access_token]"
    },
    "ig-auth": {
      "handler": "./index.js:igAuth",
      "description": "Authenticate Instagram Business Account",
      "args": "[ig_user_id] [access_token]"
    },
    "x-auth": {
      "handler": "./index.js:xAuth",
      "description": "Authenticate X (Twitter) Account",
      "args": "[api_key] [api_secret] [access_token] [access_secret]"
    },
    "threads-auth": {
      "handler": "./index.js:threadsAuth",
      "description": "Authenticate Threads Account",
      "args": "[access_token]"
    }
  }
}
